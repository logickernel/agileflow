.github/

# Development scripts
scripts/
*.sh

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp

